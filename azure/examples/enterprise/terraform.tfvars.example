subscription_id     = "12345678-1234-1234-1234-123456789012"
resource_group_name = "materialize-enterprise-rg"
name_prefix         = "mz-enterprise"
location            = "westus2"
license_key         = "your-materialize-license-key"

# Restrict access to the AKS API server. Required (no default). For lab use
# you may pass ["0.0.0.0/0"], but production should pin a tight allowlist.
k8s_apiserver_authorized_networks = ["203.0.113.0/24"]

# Public hostnames the browser uses. After apply, point A records at the LB
# IPs (see "Get LB IPs" in the README). The materialize_console_hostname is
# also used as the OAuth2 redirect URI registered with Hydra.
ory_hydra_hostname             = "hydra.mz.example.com"
ory_ui_hostname                = "auth.mz.example.com"
ory_kratos_hostname            = "kratos.mz.example.com"
materialize_console_hostname   = "console.mz.example.com"
materialize_balancerd_hostname = "balancerd.mz.example.com"

# Optional: deploy Ory Polis (SAML-to-OIDC bridge). When true, set
# ory_polis_hostname and point an A record at the polis LB IP after apply.
# Both the Polis chart and image are pulled through the Materialize OEL
# registry proxy using the license-key JWT above, no extra credential needed.
# enable_polis       = true
# ory_polis_hostname = "polis.mz.example.com"

# Optional: bring your own cert-manager (Cluster)Issuer for browser-facing
# TLS. Leave commented out to use the in-cluster self-signed issuer (browser
# trust warnings). See the README for a Let's Encrypt + Cloudflare snippet.
# cert_issuer_ref = {
#   name = "letsencrypt-prod"
#   kind = "ClusterIssuer"
# }

# Optional: federate logins through one or more upstream IdPs (Okta, Entra,
# Auth0, Google Workspace). Each entry renders as a "Sign in with X" button
# on the selfservice UI. Leave as [] for password-only login.
# upstream_oidc_providers = [
#   {
#     id            = "okta"
#     provider      = "generic"
#     client_id     = "your-okta-client-id"
#     client_secret = "your-okta-client-secret"
#     issuer_url    = "https://your-org.okta.com/oauth2/default"
#     label         = "Okta"
#   },
# ]

tags = {
  environment = "demo"
  project     = "materialize-enterprise"
}
